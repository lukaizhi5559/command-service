      "slack message",
      "slack channel",
      "slack notification"
    ],
    "providers": {
      "slack": {
        "tool": "slack",
        "installCmd": "brew install --cask slack-cli",
        "installSource": "brew-cask",
        "probeCmd": "slack --version",
        "helpCmd": "slack --help",
        "authType": "env",
        "authEnv": [
          "SLACK_BOT_TOKEN",
          "SLACK_CHANNEL_ID"
        ],
        "exampleCmds": [
          "slack message send --channel C1234567 --text 'Hello from ThinkDrop'"
        ],
        "links": [
          {
            "label": "Slack API",
            "url": "https://api.slack.com/apps"
          }
        ]
      }
    },
    "defaultProvider": "slack"
  },
