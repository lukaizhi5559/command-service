{
  "sms": {
    "keywords": [
      "sms",
      "text message",
      "text me",
      "send text",
      "send sms",
      "messaging",
      "twilio"
    ],
    "providers": {
      "twilio": {
        "tool": "twilio",
        "installCmd": "npm install -g twilio-cli",
        "installSource": "npm",
        "probeCmd": "twilio --version",
        "helpCmd": "twilio --help",
        "authType": "env",
        "authEnv": [
          "TWILIO_ACCOUNT_SID",
          "TWILIO_AUTH_TOKEN",
          "TWILIO_PHONE_NUMBER"
        ],
        "exampleCmds": [
          "twilio api:core:messages:create --from +15551234567 --to +15559876543 --body 'Hello'"
        ],
        "links": [
          {
            "label": "Twilio Console",
            "url": "https://console.twilio.com"
          }
        ]
      }
    },
    "defaultProvider": "twilio"
  },
  "github": {
    "keywords": [
      "github",
      "pull request",
      "pr",
      "issue",
      "repo",
      "repository",
      "commit",
      "branch",
      "merge",
      "git hub"
    ],
    "providers": {
      "gh": {
        "tool": "gh",
        "installCmd": "brew install gh",
        "installSource": "brew",
        "probeCmd": "gh --version",
        "helpCmd": "gh --help",
        "authType": "oauth",
        "authCmd": "gh auth login",
        "authEnv": [],
        "exampleCmds": [
          "gh pr create --title 'My PR' --body 'Description'",
          "gh issue create --title 'Bug' --body 'Details'",
          "gh repo list",
          "gh pr view <number> --json title,body,files",
          "gh pr checks <number>"
        ],
        "links": [
          {
            "label": "GitHub CLI docs",
            "url": "https://cli.github.com/manual/"
          }
        ]
      }
    },
    "defaultProvider": "gh"
  },
  "slack": {
    "keywords": [
      "slack",
